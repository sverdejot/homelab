#!/usr/bin/env bash
#MISE description="Build agent SD image. Usage: mise run build:agent <node-number> (e.g. 1)"
set -euo pipefail
NODE=${1:?node number required}
FLAKE="nixosConfigurations.homelab-${NODE}-image.config.system.build.sdImage"

if [ "${GITHUB_ACTIONS:-}" = "true" ]; then
  nix build --extra-experimental-features "nix-command flakes" --accept-flake-config ".#${FLAKE}" -L
  IMG=$(find -L result -name "*.img.zst" | head -1)
  nix shell nixpkgs#zstd --command zstd -d "$IMG" -o "homelab-${NODE}.img"
  rm result
else
  docker run --rm -v "$(pwd)":/app -w /app -e NODE="$NODE" nixos/nix:latest bash -c '
    set -euo pipefail
    nix --extra-experimental-features "nix-command flakes" --accept-flake-config build \
      ".#nixosConfigurations.homelab-${NODE}-image.config.system.build.sdImage" --out-link /tmp/img
    IMG=$(find -L /tmp/img -name "*.img.zst" | head -1)
    nix --extra-experimental-features "nix-command flakes" shell nixpkgs#zstd \
      --command zstd -d "$IMG" -o /app/homelab-${NODE}.img
  '
fi
