#!/usr/bin/env bash
#MISE description="Apply config changes to agent node without reflashing. Usage: mise run switch:agent <node-number>"
set -euo pipefail
NODE=${1:?node number required}
nix run nixpkgs#nixos-rebuild -- switch --flake ".#homelab-${NODE}-image" \
  --target-host "homelab@192.168.1.$((NODE + 2))" \
  --build-host "homelab@192.168.1.$((NODE + 2))" \
  --sudo
