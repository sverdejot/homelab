#!/usr/bin/env bash
#MISE description="Flash pre-built agent image to SD. Usage: mise run flash:sd:agent <node-number> <device> (e.g. 1 rdisk4)"
set -euo pipefail
NODE=${1:?node number required}
DEVICE=${2:?device required}
sudo dd if="homelab-$NODE.img" of=/dev/"$DEVICE" bs=4M status=progress && sudo sync
